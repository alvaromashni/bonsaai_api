# Database Configuration
# REQUIRED: Full database URL (JDBC format)
# Development: jdbc:postgresql://localhost:5432/habitsdb
# Production: Use the URL provided by your database service (Railway, Render, etc.)
DB_URL=jdbc:postgresql://localhost:5432/habitsdb

# REQUIRED: Database username
DB_USERNAME=habitsuser

# REQUIRED: Database password (no default for security)
DB_PASSWORD=your_database_password_here

# OAuth2 Google Configuration
# REQUIRED: Get your credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Development/Debug Configuration
# OPTIONAL: Enable SQL logging in console (default: false)
# Set to 'true' only in development for debugging
SHOW_SQL=false

# Frontend Configuration
# REQUIRED: The URL of your frontend application
# Development: http://localhost:5173
# Production: https://bonsaai-front.vercel.app
FRONTEND_URL=https://bonsaai-front.vercel.app
